#set -x

APPLICATION="`${HOME}/providerscripts/utilities/ExtractConfigValue.sh 'APPLICATION'`"

if ( [ "${APPLICATION}" = "joomla" ] && [ -d /var/www/html/administrator ] && [ -d /var/www/html/modules ] && [ -d /var/www/html/plugins ] )
then
    /bin/echo "1"
elif ( [ "${APPLICATION}" = "wordpress" ] &&  [ -f /var/www/html/wp-login.php ] )
then
   /bin/echo "1"

elif ( [ "${APPLICATION}" = "moodle" ] && [ -f /var/www/html/moodle/index.php ] )
then
    /bin/echo "1"
elif ( [ "${APPLICATION}" = "drupal" ] && [ -f /var/www/html/core/misc/drupal.js ] )
then
    /bin/echo "1"
fi
